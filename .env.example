# =====================================================
# Moataz AI — Vercel / Local environment
# Never commit real values.
# =====================================================

# Browser-safe Supabase values
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=YOUR_SB_PUBLISHABLE_KEY
# Legacy fallback only; leave unset when using a publishable key.
VITE_SUPABASE_ANON_KEY=
# Backward-compatible aliases accepted by the Vite client (public values only).
# Use either the VITE_* names above or the NEXT_PUBLIC_* names, not mixed projects.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only Supabase values
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_PUBLISHABLE_KEY=YOUR_SB_PUBLISHABLE_OR_LEGACY_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY

# 32+ characters; encrypts provider API keys with AES-256-GCM
ENCRYPTION_KEY=GENERATE_A_RANDOM_SECRET_AT_LEAST_32_CHARACTERS

# Authentication behavior
ALLOW_PUBLIC_SIGNUP=false
USERNAME_EMAIL_DOMAIN=users.moataz.invalid
# Public browser redirect target for magic-link authentication (never a secret).
# Keep this on the deployed HTTPS origin so links requested from localhost do not point to localhost.
VITE_APP_URL=https://moatazasaif.vercel.app
NEXT_PUBLIC_APP_URL=

# One-time owner bootstrap. Delete token/password after successful bootstrap and redeploy.
BOOTSTRAP_OWNER_EMAIL=mtzallqmy@gmail.com
BOOTSTRAP_OWNER_PASSWORD=
BOOTSTRAP_TOKEN=

# Provider runtime
APP_URL=https://YOUR_DOMAIN.example
PROVIDER_TIMEOUT_MS=45000
# Maximum upstream response body accepted by an adapter (bytes).
PROVIDER_MAX_RESPONSE_BYTES=5242880
# Upper bound sent to providers when the request does not specify one.
PROVIDER_MAX_OUTPUT_TOKENS=4096
# Keep false in production. In local tests only, this may allow localhost HTTP URLs.
ALLOW_INSECURE_PROVIDER_URLS=false

# Telegram Bot API (tokens are entered per user and encrypted in Supabase)
TELEGRAM_API_TIMEOUT_MS=15000
TELEGRAM_WEBHOOK_PROCESSING_TIMEOUT_MS=45000
TELEGRAM_MAX_CONTEXT_MESSAGES=20
TELEGRAM_MAX_RESPONSE_CHARACTERS=16000

# Session mode needs no Supabase variable: its API key is held in sessionStorage
# and sent only with the current request. Never put provider secrets in VITE_*.

# Optional Vercel GitHub Action deployment values
VERCEL_TOKEN=
VERCEL_ORG_ID=
VERCEL_PROJECT_ID=
